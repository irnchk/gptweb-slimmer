{
  "manifest_version": 3,
  "name": "ChatGPT Long Chat Slimmer",
  "version": "0.2.0",
  "description": "Keeps only recent ChatGPT turns mounted in the page, with browser-local live tuning for long web chats.",
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ChatGPT Long Chat Slimmer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
